GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Supabase — used by HistoryService for cloud-synced check history.
# Find these in Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_or_legacy_anon_jwt

# Sentry crash + error reporting (optional). Get DSN from
# sentry.io → Settings → Projects → <your-project> → Client Keys (DSN).
# Format: https://<key>@<region>.ingest.sentry.io/<project_id>
# Leave empty to disable Sentry entirely (debug + local builds default).
SENTRY_DSN=
# Tag errors so you can filter in Sentry dashboard:
# 'production' for distributed APKs, 'staging' for emulator/test devices.
SENTRY_ENV=production
