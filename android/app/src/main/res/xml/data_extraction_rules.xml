<?xml version="1.0" encoding="utf-8"?>
<!--
  Disable cloud backup + device-to-device transfer for app data. Required so
  that uninstalling and reinstalling the app actually starts from a clean
  state — no SharedPreferences or screened-call queue is preserved by Google
  Drive auto-backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
